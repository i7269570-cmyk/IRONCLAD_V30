# =================================================
# IRONCLAD_V30 - Standard Git Ignore Profile
# =================================================

# --- Environment / Secrets (보안 및 인증 정보) ---
.env
.env.*
*.key
*.pem
*.secret
keys/
wallet/
SECURITY/

# --- Logs ---
logs/
*.log

# --- Data Folders (실시간 데이터 및 연구 데이터) ---
data/
DATA/
raw_data/
cache/
datasets/
backtest/
ticks/
candles/
orderbook/
EVIDENCE/raw_data_orderbook/
EVIDENCE/raw_data_ticks/
TRINITY_RESEARCH_CLEAN/

# --- Large/Binary Files ---
*.parquet
*.feather
*.h5
*.csv
*.gz
*.zip

# --- Database ---
*.sqlite
*.sqlite3
*.db
*.db-journal

# --- Python Cache (모든 경로의 컴파일 파일 차단) ---
**/__pycache__/
*.pyc
*.pyo
*.pyd

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- Build / Temporary ---
build/
dist/
tmp/
temp/
*.tmp

# --- IDE / Editor ---
.vscode/
.idea/
nppBackup/

# --- OS / Backup ---
.DS_Store
Thumbs.db
*.bak
*.old
*.backup
*.swp

# =================================================
# SYSTEM INTEGRITY & SSOT (무결성 유지 목록 - 화이트리스트)
# =================================================

# 아래 파일들은 시스템의 '헌법'이므로 Git 추적에서 절대 제외하지 않음 
!schema.json
!system_config.yaml
!strategy_spec.yaml
!LOCKED/**/schema.json

# --- State Management ---
# 실시간으로 변경되는 상태 파일은 버전 관리에서 제외하여 충돌을 방지합니다. 
STATE/state_stock.json
STATE/state_coin.json
STATE/state.json

# 만약 STATE 폴더의 구조(템플릿)만 유지하고 싶다면 아래 주석을 해제하세요.
# !STATE/*.json.example